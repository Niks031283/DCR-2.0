{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".netlify/functions-internal",
    "rootDir": ".",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "netlify/functions/**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "frontend"
  ]
}
